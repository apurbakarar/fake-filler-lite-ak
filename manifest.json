{
    "manifest_version": 3,
    "name": "Fake Filler Lite - AK",
    "version": "1.0",
    "description": "Auto-fill forms with custom values and fetch fields",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Fake Filler Lite - AK"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}